programa
{
	
	funcao inicio()
	{
		real comprimento
		real largura
		real area

			escreva ("Digite o comprimento:")
		leia(comprimento)

			escreva ("Digite a largura:")
		leia(largura)

		area = (comprimento * largura)

			escreva ("A área é de" + area + "m²")
	}
}
