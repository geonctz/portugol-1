programa
{
	
	funcao inicio()
	{
		inteiro senha

		faca {
			escreva("Digite 1 ou 0: ")
			leia(senha)
		
		} enquanto (senha != 1 e senha != 0)
			escreva("acesso librado")

		
	}
	
}
